# =============================================================
# Contraste Éditions — Variables d'environnement PRODUCTION
# Copier ce fichier vers .env sur le VPS et remplir les valeurs
# =============================================================

# ----- Next.js -----
NEXT_PUBLIC_DIRECTUS_URL=https://directus.contraste.tn

# Static token Directus (à créer depuis l'admin Directus après init)
# Admin → Settings → Users → admin → Token
DIRECTUS_TOKEN=VOTRE_STATIC_TOKEN_ICI

# ----- Directus -----
DIRECTUS_PUBLIC_URL=https://directus.contraste.tn
ADMIN_EMAIL=admin@contraste.tn
# Mot de passe fort — minimum 16 caractères
ADMIN_PASSWORD=CHANGEZ_MOI_MOT_DE_PASSE_FORT

# Secrets Directus — générer avec : openssl rand -base64 32
DIRECTUS_SECRET=GENEREZ_AVEC_OPENSSL_RAND_BASE64_32
DIRECTUS_KEY=GENEREZ_AVEC_OPENSSL_RAND_BASE64_32

# ----- PostgreSQL -----
DB_USER=directus
DB_DATABASE=directus
# Mot de passe fort pour la DB — générer avec : openssl rand -hex 24
DB_PASSWORD=GENEREZ_AVEC_OPENSSL_RAND_HEX_24
